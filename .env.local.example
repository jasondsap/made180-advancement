# ---------------------------------------------------------------------------
# MADe180 Advancement Platform — environment template
# Copy to `.env.local` and fill in. NEVER commit the filled-in file.
#
# Tiers (see src/lib/env.ts): REQUIRED vars must be set for the app to serve
# requests; OPTIONAL vars belong to a specific feature and are enforced at point
# of use (requireEnv), so an unconfigured future feature won't break working
# routes.
# ---------------------------------------------------------------------------

# === REQUIRED ===

# --- Database (Neon Postgres) ---
# Pooled — app request-time queries.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"
# Direct (unpooled) — migration runner only.
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# --- Stripe (platform account holds the keys) ---
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- App ---
# Public base URL — Stripe redirects, Connect account links, receipt links. No trailing slash.
APP_BASE_URL="http://localhost:3000"

# === OPTIONAL (per-feature) ===

# --- Stripe Connect (Express onboarding) ---
STRIPE_CONNECT_CLIENT_ID="ca_..."
STRIPE_CONNECT_WEBHOOK_SECRET="whsec_..."

# --- AWS Cognito + NextAuth (admin auth) ---
COGNITO_REGION="us-east-1"
COGNITO_USER_POOL_ID="us-east-1_xxxxxxxxx"
COGNITO_CLIENT_ID="xxxxxxxxxxxxxxxxxxxxxxxxxx"
COGNITO_CLIENT_SECRET="" # required for a confidential app client
COGNITO_DOMAIN="https://your-domain.auth.us-east-1.amazoncognito.com"
# Optional: defaults to https://cognito-idp.<region>.amazonaws.com/<userPoolId>
COGNITO_ISSUER=""
# NextAuth: base URL (no trailing slash) + a random 32+ char secret.
# Generate the secret with:  openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# --- Email (transactional receipts via Resend, step 6) ---
RESEND_API_KEY="re_..."
# Fallback "from" if an org has no verified receipt_from_email. Must be a
# Resend-verified sender. Blank => onboarding@resend.dev (delivers only to your
# own Resend account email).
RESEND_FROM_FALLBACK=""

# --- AI assistant (phase 2) ---
ANTHROPIC_API_KEY="sk-ant-..."
